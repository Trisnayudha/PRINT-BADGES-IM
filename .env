# Port untuk print server (default: 3000)
PORT=3000

# Nama printer — kosongkan untuk pakai printer default
# Lihat daftar printer dengan: GET /api/printers
PRINTER_NAME=HP DeskJet 4300 series usb

# Nama event di header badge
EVENT_NAME=INDONESIA MINER 2026
EVENT_SUBTITLE=CONFERENCE AND EXHIBITION

# Nama sponsor yang tampil di badge (pojok kanan atas)
SPONSOR_NAME=FLS

# Jumlah copy default per print
DEFAULT_COPIES=1
